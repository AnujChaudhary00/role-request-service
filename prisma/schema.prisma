generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum RequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model AccessRequest {
  id          String        @id @default(uuid())
  userId      String
  roleId      String
  status      RequestStatus @default(PENDING)
  comment     String?
  resolvedBy  String?
  requestedAt DateTime      @default(now())
  resolvedAt  DateTime?

  @@map("access_requests")
}

model UserHasRole {
  id        String   @id @default(uuid())
  userId    String
  roleId    String
  grantedAt DateTime @default(now())
  grantedBy String?

  @@unique([userId, roleId])
  @@map("user_has_roles")
}
